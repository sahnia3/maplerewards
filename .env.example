# MapleRewards — environment configuration
# Copy to .env and fill in values. Never commit .env.

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development                                                     # development | production
PORT=8080
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000                                      # used in Stripe redirect URLs
# Set in production WHEN the SPA + API share a parent domain (app.example.ca +
# api.example.ca). Makes auth/session/CSRF cookies first-party SameSite=Lax so
# Safari/iOS don't drop them. Leave empty for same-origin localhost dev.
COOKIE_DOMAIN=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/maplerewards?sslmode=disable

# ── Cache / sessions ─────────────────────────────────────────────────────────
# Prefer REDIS_URL on managed hosts (Railway/Upstash/Render): redis://default:pass@host:port
# (or rediss:// for TLS). If REDIS_URL is set it wins; otherwise REDIS_ADDR/PASSWORD are used.
# Production requires a password (in the URL or REDIS_PASSWORD) or the server won't boot.
REDIS_URL=
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. The server will refuse to start if APP_ENV=production
# and JWT_SECRET is empty or equals the in-tree dev fallback.
JWT_SECRET=

# ── Rate limiting (optional override) ────────────────────────────────────────
# Default 300 in dev, 60 in production. Override for load testing or paid tiers.
# RATE_LIMIT_PER_MINUTE=60

# ── AI assistant (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Strong model — complex / award / trip / points reasoning. Default below.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheap model — simple turns (definitions, "best card for X", general Q&A).
# Chat auto-routes simple turns here (~3-5x cheaper). Set equal to
# ANTHROPIC_MODEL to disable routing and always use the strong model.
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ── Travel / award search ────────────────────────────────────────────────────
SERPAPI_KEY=                                                            # Google Flights cash pricing
APIFY_TOKEN=                                                            # live award scraping
SEATSAERO_API_KEY=                                                      # award availability backup
TAVILY_API_KEY=                                                         # web search context for AI

# Hard monthly call ceilings (kill-switches; counted across API + worker).
# Apify is now CAPPED (was unlimited). Defaults are generous headroom over
# expected Pro volume — lower them for a tighter dollar ceiling.
APIFY_MONTHLY_CAP=2500                                                   # ~max paid scrapes/mo; tighten to lower the worst-case bill
SERPAPI_MONTHLY_CAP=250                                                  # free-tier default
TAVILY_MONTHLY_CAP=1000                                                  # note: enforcement not yet wired into the Tavily call path

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# CURRENT tiers — these are what live checkout uses. If unset, the default
# "Pro" checkout fails with "stripe price ID not configured".
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_PROPLUS_ANNUAL=
STRIPE_PRICE_ID_LIFETIME=
# LEGACY (backward compat with old subscriptions; not used by current checkout):
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
# Webhook must be subscribed to: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted, charge.refunded
