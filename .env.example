# MapleRewards — environment configuration
# Copy to .env and fill in values. Never commit .env.

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development                                                     # development | production
PORT=8080
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000                                      # used in Stripe redirect URLs

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/maplerewards?sslmode=disable

# ── Cache / sessions ─────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. The server will refuse to start if APP_ENV=production
# and JWT_SECRET is empty or equals the in-tree dev fallback.
JWT_SECRET=

# ── Rate limiting (optional override) ────────────────────────────────────────
# Default 300 in dev, 60 in production. Override for load testing or paid tiers.
# RATE_LIMIT_PER_MINUTE=60

# ── AI assistant (Claude Sonnet 4.5) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Travel / award search ────────────────────────────────────────────────────
SERPAPI_KEY=                                                            # Google Flights cash pricing
APIFY_TOKEN=                                                            # live award scraping
SEATSAERO_API_KEY=                                                      # award availability backup
TAVILY_API_KEY=                                                         # web search context for AI

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
