# Environment & secrets
.env
.env.local
.env.*.local

# Go — anchored to repo root so cmd/api/* and internal/repo/api* are NOT matched
/bin/
/api
/api_bin
*.exe
*.test
*.out

# Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
# Stray Next.js trace files when a build is accidentally run from repo root
/.next/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker volumes
pgdata/

# Large internal design exploration assets (kept local — frontend uses
# frontend/public/brand/ for runtime assets)
/design/
SESSION-BRIEF.pdf

# Stray compiled worker binary (use `make worker-build` to bin/worker instead)
/worker

# Python bytecode caches
__pycache__/
*.pyc
